<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Activity theme. UI is rendered by Compose; this only controls the window chrome. -->
    <style name="Theme.BookOrbit" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Themes the legacy MediaRouteButton/Cast dialogs (CastButton.kt): the app has no AppCompat
         theme of its own, so android:colorBackground and (more importantly) AppCompat's colorPrimary
         are otherwise unset/transparent here. MediaRouterThemeHelper.getRouterThemeId() resolves
         ?attr/colorPrimary directly off the context's theme (not colorBackground) to decide the
         icon-tint contrast, and crashes if it comes back as fully transparent (#0). -->
    <style name="Theme.BookOrbit.MediaRouter" parent="@style/Theme.MediaRouter">
        <item name="android:colorBackground">@color/background</item>
        <item name="colorPrimary">@color/accent</item>
    </style>
    <style name="Theme.BookOrbit.MediaRouter.Light" parent="@style/Theme.MediaRouter.Light">
        <item name="android:colorBackground">@color/background</item>
        <item name="colorPrimary">@color/accent</item>
    </style>
</resources>
